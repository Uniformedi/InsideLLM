{
  "id": null,
  "uid": "insidellm-fleet",
  "title": "InsideLLM \u00e2\u20ac\u201d Fleet Management",
  "tags": [
    "insidellm",
    "fleet",
    "enterprise"
  ],
  "timezone": "browser",
  "refresh": "5m",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Instances",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS instances FROM governance_instances WHERE status = 'active'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": 0
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Fleet Total Spend (latest sync)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT SUM(t.total_spend) AS fleet_spend FROM governance_telemetry t INNER JOIN (SELECT instance_id, MAX(synced_at) AS ms FROM governance_telemetry GROUP BY instance_id) l ON t.instance_id = l.instance_id AND t.synced_at = l.ms",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "id": 3,
      "title": "Fleet Total Users",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 9,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT SUM(t.unique_users) AS fleet_users FROM governance_telemetry t INNER JOIN (SELECT instance_id, MAX(synced_at) AS ms FROM governance_telemetry GROUP BY instance_id) l ON t.instance_id = l.instance_id AND t.synced_at = l.ms",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Compliance Score",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT AVG(t.compliance_score) AS avg_score FROM governance_telemetry t INNER JOIN (SELECT instance_id, MAX(synced_at) AS ms FROM governance_telemetry GROUP BY instance_id) l ON t.instance_id = l.instance_id AND t.synced_at = l.ms",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Critical Flags (fleet)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT SUM(t.keyword_flags_critical) AS total_critical FROM governance_telemetry t INNER JOIN (SELECT instance_id, MAX(synced_at) AS ms FROM governance_telemetry GROUP BY instance_id) l ON t.instance_id = l.instance_id AND t.synced_at = l.ms",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Instance Status",
      "description": "All registered InsideLLM deployments with last sync time and compliance score",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT i.instance_name, i.industry, i.governance_tier, i.data_classification, i.schema_version, i.last_sync_at, i.status, t.total_requests, t.total_spend, t.unique_users, t.compliance_score, t.keyword_flags_critical FROM governance_instances i LEFT JOIN LATERAL (SELECT * FROM governance_telemetry WHERE instance_id = i.instance_id ORDER BY synced_at DESC LIMIT 1) t ON true ORDER BY i.instance_name",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "active": {
                        "color": "green"
                      },
                      "inactive": {
                        "color": "red"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total_spend"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 20,
      "title": "Spend by Instance (30d)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT synced_at AS time, instance_name, total_spend FROM governance_telemetry WHERE synced_at > NOW() - INTERVAL '30 days' ORDER BY synced_at",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "id": 21,
      "title": "Compliance Score by Instance (30d)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT synced_at AS time, instance_name, compliance_score FROM governance_telemetry WHERE synced_at > NOW() - INTERVAL '30 days' ORDER BY synced_at",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 30,
      "title": "Instances by Industry",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT industry, COUNT(*) AS count FROM governance_instances WHERE status = 'active' GROUP BY industry ORDER BY count DESC",
          "format": "table"
        }
      ]
    },
    {
      "id": 31,
      "title": "Instances by Governance Tier",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 22
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT governance_tier, COUNT(*) AS count FROM governance_instances WHERE status = 'active' GROUP BY governance_tier ORDER BY count DESC",
          "format": "table"
        }
      ]
    },
    {
      "id": 32,
      "title": "Stale Instances (no sync in 24h)",
      "description": "Instances that haven't synced recently \u00e2\u20ac\u201d may need attention",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 22
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT instance_name, industry, last_sync_at, status FROM governance_instances WHERE status = 'active' AND (last_sync_at IS NULL OR last_sync_at < NOW() - INTERVAL '24 hours') ORDER BY last_sync_at NULLS FIRST",
          "format": "table"
        }
      ]
    }
  ]
}
